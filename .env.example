# Use transaction pooler for app runtime.
DATABASE_URL="postgresql://postgres.mgrtydfyftyvqdusxnxd:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"

# Use direct connection or session pooler for Drizzle schema pushes.
DATABASE_MIGRATION_URL="postgresql://postgres.mgrtydfyftyvqdusxnxd:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
PORT=5000
NODE_ENV=development

# Mobile app public API endpoint. Use your deployed API URL for APK/AAB builds.
EXPO_PUBLIC_API_URL=https://smartcampushub.onrender.com

# Optional: real credential emails. Use Brevo on Render because Gmail SMTP can timeout there.
EMAIL_PROVIDER=brevo
BREVO_API_KEY="xkeysib_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="SmartCampusHub <verified-sender@example.com>"
EMAIL_REPLY_TO="admin@example.com"

# Gmail SMTP is useful for local testing, but it can timeout on Render.
GMAIL_USER="yourgmail@gmail.com"
GMAIL_APP_PASSWORD="your_16_character_google_app_password"

# Optional: Resend is recommended later after verifying your own domain.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="SmartCampusHub <noreply@yourdomain.com>"
