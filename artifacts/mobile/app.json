{
  "expo": {
    "name": "SmartCampusHub",
    "slug": "smart-campus-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartcampushub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smartcampushub.app"
    },
    "android": {
      "package": "com.smartcampushub.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1E3A8A"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "Set EXPO_PUBLIC_API_URL in eas.json for builds",
      "eas": {
        "projectId": "c7ed08e1-b402-468e-b5d5-c70d39893714"
      }
    },
    "owner": "kavyasree_kanduri"
  }
}
